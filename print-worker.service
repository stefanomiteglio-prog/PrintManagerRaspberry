[Unit]
Description=Raspberry Pi Print Worker for CUPS
After=network.target cups.service
Requires=cups.service

[Service]
Type=simple
User=pi-nexthouse
WorkingDirectory=/home/pi-nexthouse/PrintManagerRaspberry
ExecStart=/home/pi-nexthouse/PrintManagerRaspberry/.venv/bin/python worker.py
Restart=always
RestartSec=10
StandardOutput=inherit
StandardError=inherit

[Install]
WantedBy=multi-user.target
